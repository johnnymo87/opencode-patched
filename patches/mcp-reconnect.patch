   const sanitize = (s: string) => s.replace(/[^a-zA-Z0-9_-]/g, "_")
 
+  /**
+   * Detect transport-level errors that indicate a stale MCP session.
+   * These occur when the MCP server restarts (invalidating session IDs)
+   * or becomes unreachable, and warrant an automatic reconnect attempt.
+   */
+  function isTransportError(err: unknown): boolean {
+    if (!(err instanceof Error)) return false
+    const msg = err.message.toLowerCase()
+    return (
+      msg.includes("session") ||
+      msg.includes("status: 404") ||
+      msg.includes("status: 410") ||
+      msg.includes("econnrefused") ||
+      msg.includes("econnreset") ||
+      msg.includes("fetch failed")
+    )
+  }
